---
import MainLayout from '../layouts/MainLayout.astro';

const turkiPoster = {
    name: "Umroh Plus Turkey 2026",
    front: "/PaketTurki1.webp",
    back: "/PaketTurki1a.webp",
    price: "Mulai 38 Jt an",
    duration: "16 Hari",
    route: "Jakarta-Istanbul-Jeddah",
    departure: "Agustus 2026"
};
---

<MainLayout title="Umroh Plus Turkey 2026 - Samira Travel" description="Paket Umroh Plus Turki 16 hari. Kunjungi Tanah Suci dan wisata religi Turki. Harga mulai 38 juta. Fasilitas lengkap, tour leader berpengalaman.">
    <div class="bg-samira-dark text-white pt-32 pb-16">
        <div class="container mx-auto px-4 text-center">
            <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">Umroh Plus Turki</h1>
            <p class="text-samira-gold text-xl font-bold tracking-widest uppercase italic">Jadwal Musim Berikutnya Segera Hadir</p>
        </div>
    </div>

    <section class="container mx-auto px-4 py-24">
        <div class="max-w-3xl mx-auto text-center bg-white p-12 rounded-3xl shadow-xl border border-gray-100">
            <div class="w-24 h-24 bg-samira-gold/10 rounded-full flex items-center justify-center mx-auto mb-8">
                <svg class="w-12 h-12 text-samira-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
            </div>
            <h2 class="text-3xl font-bold text-samira-dark mb-4">Paket Belum Tersedia</h2>
            <p class="text-gray-500 text-lg mb-10">Saat ini jadwal keberangkatan Umroh Plus Turki untuk musim awal 2026 telah terisi penuh atau melewati tanggal. Kami sedang menyiapkan jadwal terbaru untuk akhir tahun 2026 dan awal 2027.</p>
            
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="https://wa.me/6285811112788?text=Assalamualaikum,%20saya%20ingin%20info%20jadwal%20Umroh%20Plus%20Turki%20terbaru" target="_blank" class="bg-samira-green text-white px-8 py-4 rounded-2xl font-bold text-lg hover:bg-emerald-800 shadow-lg transition">
                    Tanya Jadwal Terbaru
                </a>
                <a href="/paket-umroh" class="bg-samira-gold text-white px-8 py-4 rounded-2xl font-bold text-lg hover:bg-yellow-600 shadow-lg transition">
                    Lihat Paket Umroh Reguler
                </a>
            </div>
        </div>
    </section>

    <div id="flyer-modal" class="fixed inset-0 z-100 hidden overflow-y-auto bg-black/95 backdrop-blur-sm p-4">
        <button id="close-modal" class="fixed top-6 right-6 z-110 bg-white rounded-full p-2 text-black shadow-2xl" aria-label="Close modal">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
        <div class="flex flex-col items-center max-w-4xl mx-auto pt-10 pb-20">
            <h2 id="modal-title" class="text-white font-serif text-2xl mb-8"></h2>
            <div class="flex flex-col gap-8 w-full">
                <img id="modal-img-front" src="" class="w-full h-auto rounded-lg shadow-2xl border-2 border-white/10" />
                <img id="modal-img-back" src="" class="w-full h-auto rounded-lg shadow-2xl border-2 border-white/10" style="display: none;" />
            </div>
        </div>
    </div>

    <script>
        const modal = document.getElementById('flyer-modal')!;
        const closeBtn = document.getElementById('close-modal')!;
        const modalTitle = document.getElementById('modal-title')!;
        const modalImgFront = document.getElementById('modal-img-front') as HTMLImageElement;
        const modalImgBack = document.getElementById('modal-img-back') as HTMLImageElement;
        const openElems = document.querySelectorAll<HTMLElement>('.btn-open-modal');

        openElems.forEach(elem => {
            elem.addEventListener('click', () => {
                const backUrl = elem.getAttribute('data-back');
                modalTitle.textContent = elem.getAttribute('data-name')!;
                modalImgFront.src = elem.getAttribute('data-front')!;
                
                if (backUrl && backUrl.trim() !== "") {
                    modalImgBack.src = backUrl;
                    modalImgBack.style.display = 'block';
                } else {
                    modalImgBack.style.display = 'none';
                }
                
                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            });
        });

        const closeModal = () => {
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto';
        };

        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
        });
    </script>
</MainLayout>